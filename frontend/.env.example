# Required for NextAuth
NEXTAUTH_SECRET=changeme
# username for admin login
ADMIN_USERNAME=admin
# SHA256 hash of your admin password
ADMIN_PASSWORD_SHA256=sha256digest
# Alternatively, provide a plain password for testing
# ADMIN_PASSWORD=plainpassword


# Optional defaults for VPS tab (SFTP/SSH)
NEXT_PUBLIC_VPS_HOST=
NEXT_PUBLIC_VPS_PORT=22
NEXT_PUBLIC_VPS_USERNAME=
NEXT_PUBLIC_VPS_PASSWORD=
NEXT_PUBLIC_VPS_PRIVATE_KEY=
NEXT_PUBLIC_VPS_PATH=/etc/nginx/sites-available
NEXT_PUBLIC_VPS_DEFAULT_COMMAND=nginx -t
